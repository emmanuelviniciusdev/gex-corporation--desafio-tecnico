# Integration API Configuration
# Copy this file to .env and fill in the values

APP_NAME=Integration API
APP_VERSION=0.1.0
DEBUG=false

# Database: use MySQL service from docker-compose
DATABASE_URL=mysql+pymysql://root:root@mysql:3306/db_integration

# Redis service
REDIS_URL=redis://redis:6379/0

# RabbitMQ service
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

#
# Optional: AES-256 key for Grummer (base64).
#
# Emmanuel's note: this is not a real secret value!!
GRUMMER_AES256_KEY_BASE64=YmQ4ZmU2NDNhNmUxYjcyNWRiMTM2MTA0ZWZlYmU0NTAyNDNlZDdlZjZjNmE3NTVhYjliMjMxNWZiNjQ4ZjE1Mw==

